PORT=5000
# Local dev without Docker: use embedded MongoDB (recommended)
USE_MEMORY_DB=true
# If USE_MEMORY_DB=false, point to a real MongoDB:
# MONGODB_URI=mongodb://127.0.0.1:27017/student_interview_tracker
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
NODE_ENV=development
# Set to false to skip auto demo seed on empty DB (non-production)
# AUTO_SEED=true
